{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "tmake",
  "scopeName": "source.tmake",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#builtin-functions" },
    { "include": "#keywords" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.tmake",
          "match": "//.*$"
        },
        {
          "name": "comment.block.tmake",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.tmake",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "variable.other.argument.tmake",
              "match": "\\$\\d+"
            },
            {
              "name": "constant.other.glob.tmake",
              "match": "\\*\\*|\\*"
            }
          ]
        }
      ]
    },
    "builtin-functions": {
      "patterns": [
        {
          "name": "entity.name.function.builtin.tmake",
          "match": "\\b(COMPILER|VERSION|PROGRAM|PRINT)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.tmake",
          "match": "\\b(var|if|else)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.tmake",
          "match": "==|!="
        },
        {
          "name": "keyword.operator.logical.tmake",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.assignment.tmake",
          "match": "(?<!=|!)=(?!=)"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.tmake",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        }
      ]
    }
  }
}
